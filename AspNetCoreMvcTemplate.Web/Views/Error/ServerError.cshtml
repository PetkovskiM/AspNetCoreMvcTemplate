@model AspNetCoreMvcTemplate.Web.ViewModels.Error.ServerErrorViewModel

@{
    ViewData["Title"] = "Server Error";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4 p-md-5 text-center">
                    <div class="display-1 fw-bold text-danger mb-3">500</div>
                    <h1 class="h2 fw-semibold mb-3">Something went wrong</h1>
                    <p class="text-muted mb-4">
                        An unexpected error occurred while processing your request.
                    </p>

                    @if (Model.ShowRequestId)
                    {
                        <div class="alert alert-light border rounded-3 text-start mx-auto mb-4" style="max-width: 500px;">
                            <strong>Request ID:</strong>
                            <code>@Model.RequestId</code>
                        </div>
                    }

                    <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-danger px-4">
                            Go to home
                        </a>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">
                            Go back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>